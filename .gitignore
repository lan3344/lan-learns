# === 全量备份 .gitignore ===
# 排除第三方依赖和可重建的大文件，只保留核心数据

# node_modules（第三方依赖，可重建）
node_modules/

# 嵌入模型（可从huggingface重新下载）
*.safetensors
embedding_model/

# openclaw 源码（开源，可重新clone）
openclaw_src/
openclaw_src.zip

# 大型打包文件
lan_pack_*.zip

# Python缓存
__pycache__/
*.pyc
*.pyo

# .consolidator 临时数据
.consolidator/

# 系统文件
.DS_Store
Thumbs.db
desktop.ini

# 临时文件
tmp/
tmp_mobile_echo/
*.tmp
